# Copy this to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=opama
POSTGRES_USER=opama
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://opama:change_me_in_production@localhost:5432/opama

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth provider ───────────────────────────────────────────────────────────
# "local"    — username/password accounts, zero external setup (OSS default;
#              this is what you get if AUTH_PROVIDER is left unset)
# "firebase" — Firebase-backed accounts (needed for opama Cloud / multi-tenant)
AUTH_PROVIDER=local
# Required when AUTH_PROVIDER=local — signs local-account tokens. Generate
# with `openssl rand -hex 32` and keep it stable (rotating it logs everyone out).
LOCAL_AUTH_SECRET=
# Optional — how long local-account tokens stay valid, in days (default: 365).
# Long-lived by design for the low-friction self-hosted "command station" use
# case; short-lived/refresh tokens are a future "Sessions & Security" plugin.
# LOCAL_AUTH_TOKEN_TTL_DAYS=365
#
# Local accounts may be created without a password for frictionless local-only
# use. opama nudges (banner) and, once CORS_ORIGINS below names a non-local
# origin, prompts (modal) the account to set one — see CLAUDE.md "Security".

# ── Firebase ────────────────────────────────────────────────────────────────
# Only needed when AUTH_PROVIDER=firebase.
FIREBASE_WEB_API_KEY=
FIREBASE_PROJECT_ID=
# Path to your Firebase service account JSON (download from Firebase Console)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── AI provider (used by /ai/chat, /suggest/chat, /suggest/ai) ──────────────
# openai | anthropic | ollama
AI_PROVIDER=openai

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic ───────────────────────────────────────────────────────────────
# Required only when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# ── eBay ────────────────────────────────────────────────────────────────────
EBAY_ENV=SANDBOX
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_SITE_ID=0

# ── CORS (comma-separated origins, defaults to localhost dev) ────────────────
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Ollama (optional local LLM) ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Plugins ─────────────────────────────────────────────────────────────────
# Comma-separated plugin IDs to load. Leave empty to load all discovered plugins.
# Example (core-only): ENABLED_PLUGINS=custom_assets,system,integrations,licensing,plugin_store
# ENABLED_PLUGINS=
# Comma-separated directories of external plugin packages — each subdirectory
# holds its own plugin.yaml, mirroring the services/<id>/ convention. This is
# how premium plugins (e.g. opama_marketplace) load from outside this repo —
# see external_plugins/README.md for the package layout and naming convention.
# PLUGIN_PATHS=/app/external_plugins

# ── OpenClaw Integration ─────────────────────────────────────────────────────
# Shared secret between the opama backend and the OpenClaw opama agent.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
OPENCLAW_API_TOKEN=
# Database user ID that the opama agent acts on behalf of (usually 1)
OPENCLAW_USER_ID=1
